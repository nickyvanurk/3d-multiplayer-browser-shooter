{
  "name": "voidfall",
  "version": "1.0.0",
  "description": "3D multiplayer space shooter game.",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "client:start:dev": "vite --config client/vite.config.js",
    "client:build": "vite build --config client/vite.config.js",
    "server:start:dev": "nodemon --config server/nodemon.json server/src/index.js",
    "server:start": "node server/src/index.js",
    "postinstall": "npm run client:build",
    "start": "PRODUCTION=true npm run server:start",
    "test:sim": "node test/sim/index.js",
    "lint": "eslint . --ext .js",
    "lint-and-fix": "eslint . --ext .js --fix"
  },
  "author": "N. van Urk",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^2.0.4",
    "puppeteer": "^5.3.1",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "ammo.js": "github:kripken/ammo.js",
    "atob": "^2.1.2",
    "blob-util": "^2.0.2",
    "cross-blob": "^2.0.0",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "sanitize-html": "^1.27.4",
    "three": "^0.126.1",
    "uuid": "^8.3.0",
    "winston": "^3.3.3",
    "winston-transport-browserconsole": "^1.0.5",
    "ws": "^7.3.1",
    "xmlhttprequest": "^1.8.0"
  }
}
